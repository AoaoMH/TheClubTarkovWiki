{
  "name": "the-club-wiki",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n frontend,server -c cyan,green \"npm run dev\" \"cd server && npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate": "cd generator && npx tsx src/index.ts",
    "generate:data": "cd generator && npx tsx src/index.ts --skip-images",
    "generate:images": "cd generator && npx tsx src/index.ts --images-only"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^24.2.3",
    "lucide-react": "^0.475.0",
    "lz-string": "^1.5.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^7.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/lz-string": "^1.3.34",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  }
}
