{"id":"68677d09339b397ed3d37522","typeName":"Pistol","category":"weapon","parentTypeChain":["Pistol","Weapon","CompoundItem","Item"],"handbook":{"categoryId":null,"price":0},"common":{"name":{"zh":"SR-2 \"Udav\" 9x21毫米手枪","en":"SR-2 Udav 9x21mm pistol"},"shortName":{"zh":"Udav","en":"Udav"},"description":{"zh":"SR-2\"Udav\"（俄文Удав意为\"蟒蛇\"，GRAU代号6P72）是一款俄罗斯研制的9×21毫米枪管短后座原理半自动手枪。该枪由中央精密机械工程研究所于2019年推出，旨在取代俄军现役的马卡洛夫PM手枪，并在发布次月通过军方测试。相比马卡洛夫手枪，该设计进行了多项改进来提供较前身更高的改装灵活性：提升握持舒适度的带有防滑纹路聚合物套筒、双侧对称操控机构、集成式配件导轨，以及可更换式瞄具系统。","en":"The SR-2 Udav (Удав - “Boa”, GRAU Index - 6P72) is a Russian 9×21mm short-recoil-operated semi-automatic pistol. It was released by Central Scientific - Research Institute of Precision Machine Engineering (TsNIITochMash) in 2019 as a replacement for the Makarov PM for the Russian military and passed military trials the month following its release date. The design has many improvements over the Makarov including a polymer frame with better texturing for more comfort, ambidextrous controls, a dedicated accessory rail built into the frame, and removable sights to offer more flexibility than its predecessor."},"weight":0.79,"width":2,"height":1,"rarity":"Rare","backgroundColor":"black"},"properties":{"_raw":{"AdjustCollimatorsToTrajectory":false,"AimPlane":0.026,"AimSensitivity":0.65,"AllowFeed":true,"AllowJam":true,"AllowMisfire":true,"AllowOverheat":true,"AllowSlide":true,"AnimationVariantsNumber":0,"BackgroundColor":"black","BaseMalfunctionChance":0.2277,"BoltAction":false,"BurstShotsCount":3,"CameraSnap":5,"CameraToWeaponAngleSpeedRange":{"x":0.1,"y":0.2,"z":0},"CameraToWeaponAngleStep":0.1,"CanPutIntoDuringTheRaid":true,"CanQueueSecondShot":true,"CanRequireOnRagfair":false,"CanSellOnRagfair":true,"CanUnloadAmmoByPlayer":true,"CantRemoveFromSlotsDuringRaid":[],"CenterOfImpact":0.22,"Chambers":[{"_id":"59f98b4986f7746f546d2cf3","_mergeSlotWithChildren":false,"_name":"patron_in_weapon","_parent":"59f98b4986f7746f546d2cef","_props":{"filters":[{"Filter":[