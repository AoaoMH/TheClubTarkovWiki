  "common": {
    "name": {
      "zh": "THOR综合型防弹服",
      "en": "NFM THOR Integrated Carrier body armor"
    },
    "shortName": {
      "zh": "THOR IC",
      "en": "THOR IC"
    },
    "description": {
      "zh": "THOR综合型防弹服有全覆盖的软质防弹板，能提供360度防护，抵挡高速弹片和手枪子弹。防弹服的前部、背部及侧部的重型防弹板可抵挡步枪子弹，保护重要器官。插板的人体工程学设计以及与背部插板一体的腰部缓冲带能为使用者带来舒适的体验，同时兼顾与身体的紧密贴合，还能将重量分散至全身。由NFM制造。",
      "en": "The THOR full protection assault body armor equipped with soft and hard armor elements to protect against shrapnel and bullets of pistol and rifle calibers. Manufactured by NFM."
    },
    "weight": 18.2,
    "width": 4,
    "height": 4,
    "rarity": "Superrare",
    "backgroundColor": "blue"
  },
