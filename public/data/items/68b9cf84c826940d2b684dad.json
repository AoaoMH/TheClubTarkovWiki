{"id":"68b9cf84c826940d2b684dad","typeName":"TacticalCombo","category":"mod_other","parentTypeChain":["TacticalCombo","FunctionalMod","Mod","CompoundItem","Item"],"handbook":{"categoryId":null,"price":0},"common":{"name":{"zh":"AN/PEQ-6 集成战术设备","en":"AN/PEQ-6 Integrated Laser Light Module"},"shortName":{"zh":"AN/PEQ-6","en":"AN/PEQ-6"},"description":{"zh":"一款由Insight Technology设计制造，专为美国特种作战司令部与 H&K Mark 23半自动手枪配套使用的激光瞄准模块。该模块左侧配置激光发射器，右侧设有两盏战术手电。激光器具备两种模式：一种产生可见光点，另一种发射红外光束。照明部分上层为矩形白光手电，下层为矩形红外手电，其中红外组件需佩戴夜视仪方可观测。","en":"A laser aiming module (LAM) designed and manufactured by Insight Technology for use by United States Special Operations Command (USSOCOM) with the Heckler & Koch Mark 23 semi-automatic pistol. It consists of a laser projector on the left side of the LAM and two tactical flashlights on the right side. One setting of the laser produces a visible light dot, while the other setting produces infrared (IR) light. The illuminator section has a rectangular white light flashlight on the upper part and a rectangular infrared flashlight on the lower part. The IR elements can only be seen whilst wearing night vision goggles."},"weight":0.19,"width":1,"height":1,"rarity":"Rare","backgroundColor":"blue"},"properties":{"_raw":{"Accuracy":0,"AnimationVariantsNumber":0,"BackgroundColor":"blue","BlocksCollapsible":false,"BlocksFolding":false,"CanPutIntoDuringTheRaid":true,"CanRequireOnRagfair":false,"CanSellOnRagfair":true,"CantRemoveFromSlotsDuringRaid":[],"ConflictingItems":[],"Description":"X400","DiscardLimit":-1,"DiscardingBlock":false,"DoubleActionAccuracyPenaltyMult":1,"DropSoundType":"None","Durability":100,"EffectiveDistance":0,"Ergonomics":-4,"ExamineExperience":10,"ExamineTime":1,"ExaminedByDefault":true,"ExtraSizeDown":0,"ExtraSizeForceAdd":false,"ExtraSizeLeft":0,"ExtraSizeRight":0,"ExtraSizeUp":0,"ForbidMissingVitalParts":false,"ForbidNonEmptyContainers":false,"Grids":[],"HasShoulderContact":false,"Height":1,"HideEntrails":false,"InsuranceDisabled":fal