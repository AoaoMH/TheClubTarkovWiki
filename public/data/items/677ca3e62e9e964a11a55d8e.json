{"id":"677ca3e62e9e964a11a55d8e","typeName":"Pistol","category":"weapon","parentTypeChain":["Pistol","Weapon","CompoundItem","Item"],"handbook":{"categoryId":null,"price":0},"common":{"name":{"zh":"LAR Grizzly 50 Mark V .50 AE手枪（黄金版）","en":"LAR Grizzly 50 Mark V .50 AE pistol (Gold)"},"shortName":{"zh":"Grizzly","en":"Grizzly"},"description":{"zh":"LAR Grizzly Mark V手枪是一款基于柯尔特M1911风格改造的手枪，其采用超大尺寸组件设计，旨在适配比标准版1911手枪更强劲的大威力弹药——此处特指.50AE弹。原型枪由Perry Arnett打造，通过切割焊接两把柯尔特1911的套筒与底把来适配.45温彻斯特马格南弹，并在套筒平面焊接双层钢板以延缓后坐速度并增强结构强度。","en":"The LAR Grizzly Mark V pistol is a modified Colt M1911 style pistol with oversized components designed to handle larger, more powerful cartridges than could be used in the standard-size 1911 pistol; in this case, .50 Action Express. The original prototype built by Perry Arnett was made from two Colt 1911 frames and slides cut and welded to accommodate the .45 Winchester Magnum round, with two steel doubler plates welded to the slide flats to retard the action and increase strength."},"weight":0.432,"width":2,"height":1,"rarity":"Superrare","backgroundColor":"black"},"properties":{"_raw":{"AdjustCollimatorsToTrajectory":false,"AimPlane":0.026,"AimSensitivity":0.65,"AllowFeed":true,"AllowJam":true,"AllowMisfire":true,"AllowOverheat":true,"AllowSlide":true,"AnimationVariantsNumber":0,"BackgroundColor":"black","BaseMalfunctionChance":0.2277,"BoltAction":false,"BurstShotsCount":3,"CameraSnap":1.2,"CameraToWeaponAngleSpeedRange":{"x":0.1,"y":0.2,"z":0},"CameraToWeaponAngleStep":0.1,"CanPutIntoDuringTheRaid":true,"CanQueueSecondShot":true,"CanRequireOnRagfair":false,"CanSellOnRagfair":false,"CanUnloadAmmoByPlayer":true,"CantRemoveFromSlotsDuringRaid":[],"CenterOfImpact":0,"Chambers":[{"_id":"669fa3f88abd2662d80eee7d","_mergeSlotWithChildren":false,"_name":"patron_in_weapon","_parent":"669fa3f88abd2662d80eee77","_props":{"filters":[{"Filter":["668fe62ac62660a5d8071446","66a0d1e0ed648d72fe064d06","66a0d1f88486c69fce00fdf6","66a0d1c87d0d369e270bb9de"]}]},"